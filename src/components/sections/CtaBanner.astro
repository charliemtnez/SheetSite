---
interface Props {
  title: string;
  subtitle?: string;
  button_text: string;
  button_link: string;
  [key: string]: string | undefined;
}

const { title, subtitle, button_text, button_link } = Astro.props;
---

<section class="bg-accent py-12 md:py-16 lg:py-20">
  <div class="mx-auto max-w-4xl px-6 text-center">
    <h2 class="text-2xl font-semibold text-charcoal md:text-3xl">{title}</h2>
    {subtitle && <p class="mt-3 text-charcoal/80">{subtitle}</p>}
    {button_text && button_link && (
      <a
        href={button_link}
        class="btn-secondary mt-8"
      >
        {button_text}
      </a>
    )}
  </div>
</section>
