---
interface Props {
  title: string;
  content: string;
  image_url: string;
  image_position?: string;
  [key: string]: string | undefined;
}

const { title, content, image_url, image_position = "left" } = Astro.props;
const isRight = image_position === "right";
---

<section class="py-12 md:py-16 lg:py-20">
  <div class:list={[
    "mx-auto flex max-w-7xl flex-col gap-8 px-6 md:flex-row md:items-center",
    isRight && "md:flex-row-reverse",
  ]}>
    <div class="md:w-1/2">
      <img
        src={image_url}
        alt={title}
        loading="lazy"
        class="w-full rounded-lg object-cover shadow-sm"
      />
    </div>
    <div class="md:w-1/2">
      <h2 class="text-2xl font-semibold text-primary md:text-3xl">{title}</h2>
      <p class="mt-4 text-charcoal leading-relaxed">{content}</p>
    </div>
  </div>
</section>
