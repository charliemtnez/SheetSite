---
import type { DirectoryItem } from "@data/types";

interface Props {
  item: DirectoryItem;
  filterField?: string;
}

const { item, filterField } = Astro.props;
const filterValue = filterField ? (item as Record<string, unknown>)[filterField] as string : undefined;
---

<article
  class="overflow-hidden rounded-lg border border-mist bg-white shadow-sm"
  data-filter-value={filterValue || ""}
>
  {item.image_url ? (
    <img
      src={item.image_url}
      alt={`Photo of ${item.name}`}
      loading="lazy"
      class="h-48 w-full object-cover"
    />
  ) : (
    <div class="flex h-48 items-center justify-center bg-mist text-4xl text-primary/40" aria-hidden="true">
      {item.name.charAt(0)}
    </div>
  )}
  <div class="p-4">
    <h3 class="text-lg font-serif font-semibold text-primary">{item.name}</h3>
    <p class="text-sm text-charcoal/70">{item.role}</p>
    {item.specialty && (
      <span class="mt-2 inline-block rounded bg-accent/20 px-2 py-0.5 text-xs font-medium text-charcoal">
        {item.specialty}
      </span>
    )}
    <p class="mt-3 text-sm text-charcoal">{item.bio}</p>
  </div>
</article>
