---
import type { Section } from "@data/types";
import Hero from "@components/sections/Hero.astro";
import Features from "@components/sections/Features.astro";
import Testimonials from "@components/sections/Testimonials.astro";
import CtaBanner from "@components/sections/CtaBanner.astro";
import TextBlock from "@components/sections/TextBlock.astro";
import ImageText from "@components/sections/ImageText.astro";
import DynamicForm from "@components/sections/DynamicForm.astro";

interface Props {
  section: Section;
}

const { section } = Astro.props;
const { type, props } = section;
---

{type === "hero" && <Hero {...props} />}
{type === "features" && <Features {...props} />}
{type === "testimonials" && <Testimonials {...props} />}
{type === "cta_banner" && <CtaBanner {...props} />}
{type === "text_block" && <TextBlock {...props} />}
{type === "image_text" && <ImageText {...props} />}
{type === "form" && <DynamicForm {...props} />}
{!["hero", "features", "testimonials", "cta_banner", "text_block", "image_text", "form", "directory_header", "directory_item"].includes(type) && import.meta.env.DEV && (
  <div class="border-2 border-dashed border-red-400 bg-red-50 p-4 text-red-700">
    Unknown section type: &quot;{type}&quot;
  </div>
)}
